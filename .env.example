# ==============================
# 应用基础配置
# ==============================
APP_NAME="FastAPI Template"
APP_ENV=development          # development | staging | production
APP_DEBUG=true
APP_HOST=0.0.0.0
APP_PORT=8000

# Uvicorn worker 进程数
# APP_DEBUG=true 时固定使用 1 个 worker，避免热重载与多进程冲突。
# APP_DEBUG=false 且未设置 WEB_CONCURRENCY 时，默认使用 min(CPU 核心数, 4)。
# 生产环境可显式设置，例如 WEB_CONCURRENCY=4。
# WEB_CONCURRENCY=4

# Jwt 密钥
SECRET_KEY=your-secret-key-change-this-in-production

# ==============================
# MySQL 配置（使用 Tortoise-ORM）
# ==============================
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=your_password
MYSQL_DB=your_database

# MySQL 连接池配置
# 注意：这是“每个应用 worker 进程”的连接池大小。
# 理论最大 MySQL 连接数约为 worker 数 * MYSQL_POOL_MAX。
# 如果还有多台机器或多个容器副本，还需要继续乘以实例数。
# 小型项目可保持默认值；生产环境请结合 MySQL max_connections、服务实例数和接口耗时调整。
MYSQL_POOL_MIN=3
MYSQL_POOL_MAX=10

# ==============================
# Redis 配置
# ==============================
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# Redis 最大连接数
# 注意：这是“每个应用 worker 进程”的 Redis 连接上限。
# 理论最大 Redis 连接数约为 worker 数 * REDIS_MAX_CONNECTIONS。
# 如果还有多台机器或多个容器副本，还需要继续乘以实例数。
# 如果 Redis 用得很重，比如缓存、限流、会话、验证码，可根据监控适当调大。
REDIS_MAX_CONNECTIONS=20

# ==============================
# 日志配置
# ==============================
LOG_LEVEL=INFO               # DEBUG | INFO | WARNING | ERROR
LOG_FILE=logs/app.log
